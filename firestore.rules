rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─────── Helper Functions ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && (
        request.auth.token.role == role || 
        getUserDoc().role == role
      );
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isModerator() {
      return hasRole('moderator') || isAdmin();
    }
    
    function isOfficial() {
      return hasRole('official') || isAdmin();
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function onlyAIUpdateKeys(diff) {
      return diff.affectedKeys().size() > 0 && diff.affectedKeys().hasOnly([
        'aiSummary',
        'agentResults',
        'pipelineTimeline',
        'processingMetrics',
        'aiStatus',
        'aiStatusMessage',
        'aiErrorReason',
        'updatedAt'
      ]);
    }
    
    // ─────── Users Collection ───────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
      allow delete: if isAdmin();
      
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
    }
    
    // ─────── Issues Collection (Core) ───────────────────────────────────
    match /issues/{issueId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && (
        (request.resource.data.reportedBy == request.auth.uid) ||
        (request.resource.data.reportedBy == null && request.resource.data.isAnonymous == true) ||
        (request.resource.data.reportedBy == 'demo_citizen')
      );
      

      allow update: if isAuthenticated() && (
        // Admins and moderators have full edit capabilities
        isAdmin() || isModerator() ||
        // Official: can only update issues assigned to their department
        (isOfficial() && resource.data.assignedDepartment == getUserDoc().department) ||
        // Citizen: can update or delete their own issues before department assignment
        (
          isOwner(resource.data.reportedBy)
          && (
            (
              !(resource.data.status in ['assigned', 'in_progress', 'resolved_pending_verification', 'resolved', 'closed', 'duplicate', 'rejected'])
              && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reportedBy', 'statusHistory'])
            ) ||
            // Or confirm resolution
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory', 'updatedAt'])
              && request.resource.data.status in ['closed', 'in_progress']
              && resource.data.status == 'resolved'
            )
          )
        ) ||
        // General support count increment for upvotes
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'metrics.upvoteCount',
            'metrics.shareCount',
            'supportCount',
            'supportedBy',
            'priority.score',
            'updatedAt',
            'aiStatus',
            'aiStatusMessage',
            'aiErrorReason'
          ])
        )
      );
      
      // Citizens can only delete their own issues before assignment
      allow delete: if isAdmin() || (
        isOwner(resource.data.reportedBy) 
        && !(resource.data.status in ['assigned', 'in_progress', 'resolved_pending_verification', 'resolved', 'closed', 'duplicate', 'rejected'])
      );
      
      match /statusHistory/{historyId} {
        allow read: if isAuthenticated();
        allow create: if isOfficial() || isModerator();
        allow update, delete: if false;
      }
    }
    
    // ─────── Verifications Collection ───────────────────────────────────
    match /verifications/{verificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.verifiedBy == request.auth.uid;
      allow update, delete: if false;
    }
    
    // ─────── Events Collection ──────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isOfficial() || isModerator();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
      
      match /volunteers/{volunteerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated() || isOfficial();
      }
    }
    
    // ─────── Departments Collection ────────────────────────────────────
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ─────── Categories Collection ─────────────────────────────────────
    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ─────── System Settings Collection ────────────────────────────────
    match /systemSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ─────── Moderation Logs Collection ────────────────────────────────
    match /moderationLogs/{logId} {
      allow read: if isModerator();
      allow write: if isModerator();
    }
    
    // ─────── Audit Logs Collection ─────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || isModerator();
    }
    
    // ─────── Content Reports Collection ────────────────────────────────
    match /contentReports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update: if isModerator();
      allow delete: if isModerator();
    }
    
    // ─────── Alerts Collection ──────────────────────────────────────────
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isOfficial() || isModerator();
      allow update, delete: if isOfficial() || isModerator();
    }
    
    // ─────── Executive Summaries ────────────────────────────────────────
    match /executiveSummaries/{summaryId} {
      allow read: if isOfficial();
      allow write: if false;
    }
    
    // ─────── Community Stats ────────────────────────────────────────────
    match /communityStats/{statId} {
      allow read: if true;
      allow write: if false;
    }
    
    // ─────── Discussions & Community Forum ──────────────────────────────
    match /discussions/{discussionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.authorId) || isModerator()
      );
      allow delete: if isAuthenticated(); // Allowed for seeder cleaning operations
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow delete: if (request.resource.data.authorId == request.auth.uid) || isModerator();
      }
    }
    
    // ─────── Analytics Collections ──────────────────────────────────────
    match /analytics/{docId} {
      allow read: if isOfficial() || isModerator();
      allow write: if false;
    }
  }
}
