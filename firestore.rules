rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─────── Helper Functions ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isOfficialOrAdmin() {
      return isAuthenticated() && request.auth.token.role in ['official', 'admin'];
    }
    
    function isModerator() {
      return isAuthenticated() && request.auth.token.role in ['moderator', 'admin', 'official'];
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdminOnly() {
      return isRole('admin');
    }
    
    // ─────── Users Collection ───────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isOwner(uid) || isOfficialOrAdmin();
      allow delete: if isAdminOnly();
      
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
    }
    
    // ─────── Issues Collection (Core) ───────────────────────────────────
    match /issues/{issueId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && (
        (request.resource.data.reportedBy == request.auth.uid) ||
        (request.resource.data.reportedBy == null && request.resource.data.isAnonymous == true) ||
        (request.resource.data.reportedBy == 'demo_citizen')
      );
      
      function onlyAIUpdateKeys(diff) {
        return diff.affectedKeys().size() > 0 && diff.affectedKeys().hasOnly([
          'aiSummary',
          'agentResults',
          'pipelineTimeline',
          'processingMetrics',
          'aiStatus',
          'aiStatusMessage',
          'aiErrorReason',
          'updatedAt'
        ]);
      }

      allow update: if isAuthenticated() && (
        // Officials, admins, and moderators can update any issue (department, worker, lifecycle, escalation)
        isOfficialOrAdmin() || isModerator() ||
        // Citizens can confirm/reopen their own issues
        (
          isOwner(resource.data.reportedBy)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'statusHistory',
            'updatedAt'
          ])
          && request.resource.data.status in ['closed', 'in_progress']
          && resource.data.status == 'resolved'
        ) ||
        // Citizens can support issues, increment upvotes, boost priorities, or submit lightweight interaction updates
        (request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly([
             'metrics.upvoteCount',
             'metrics.shareCount',
             'supportCount',
             'supportedBy',
             'priority.score',
             'updatedAt',
             'aiStatus',
             'aiStatusMessage',
             'aiErrorReason'
           ])) ||
        // Allow issue owner or anonymous creators to update AI pipeline tags
        (
          isOwner(resource.data.reportedBy)
          && onlyAIUpdateKeys(request.resource.data.diff(resource.data))
        ) ||
        (
          resource.data.reportedBy == null
          && resource.data.isAnonymous == true
          && onlyAIUpdateKeys(request.resource.data.diff(resource.data))
        )
      );
      
      allow delete: if isAdminOnly();
      
      match /statusHistory/{historyId} {
        allow read: if isAuthenticated();
        allow create: if isOfficialOrAdmin() || isModerator();
        allow update, delete: if false;
      }
    }
    
    // ─────── Verifications Collection ───────────────────────────────────
    match /verifications/{verificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.verifiedBy == request.auth.uid;
      allow update, delete: if false;
    }
    
    // ─────── Events Collection ──────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isOfficialOrAdmin() || isModerator();
      allow update: if isAuthenticated();
      allow delete: if isAdminOnly();
      
      match /volunteers/{volunteerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated() || isOfficialOrAdmin();
      }
    }
    
    // ─────── Departments Collection ────────────────────────────────────
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOnly();
    }
    
    // ─────── Alerts Collection ──────────────────────────────────────────
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isOfficialOrAdmin() || isModerator();
      allow update, delete: if isOfficialOrAdmin() || isModerator();
    }
    
    // ─────── Executive Summaries ────────────────────────────────────────
    match /executiveSummaries/{summaryId} {
      allow read: if isOfficialOrAdmin();
      allow write: if false;
    }
    
    // ─────── Community Stats ────────────────────────────────────────────
    match /communityStats/{statId} {
      allow read: if true;
      allow write: if false;
    }
    
    // ─────── Discussions & Community Forum ──────────────────────────────
    match /discussions/{discussionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow delete: if (request.resource.data.authorId == request.auth.uid) || isModerator();
      }
    }
    
    // ─────── Analytics Collections ──────────────────────────────────────
    match /analytics/{docId} {
      allow read: if isOfficialOrAdmin() || isModerator();
      allow write: if false;
    }
  }
}
